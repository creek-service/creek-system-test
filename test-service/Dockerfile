FROM amazoncorretto:26@sha256:6ea266d64d1995d81834934a070fe185331d5d1659baf464896b02db651d227c
ARG APP_NAME
ARG APP_VERSION
ENV VERSION=$APP_VERSION


RUN mkdir -p /opt/creek

COPY bin /bin
COPY log4j /log

COPY ${APP_NAME}-${APP_VERSION} /opt/creek/${APP_NAME}-${APP_VERSION}
WORKDIR /opt/creek
RUN ln -s ${APP_NAME}-${APP_VERSION} service

ENTRYPOINT ["/bin/run.sh"]